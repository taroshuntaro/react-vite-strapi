# --- PostgreSQL ---
POSTGRES_VERSION=17
DATABASE_NAME=strapi
DATABASE_USERNAME=strapi
DATABASE_PASSWORD=replace-with-local-password

# --- Strapi secrets (generate real values with: openssl rand -base64 32) ---
APP_KEYS=replace-with-generated-key1,replace-with-generated-key2
API_TOKEN_SALT=replace-with-generated-value
ADMIN_JWT_SECRET=replace-with-generated-value
TRANSFER_TOKEN_SALT=replace-with-generated-value
JWT_SECRET=replace-with-generated-value
ENCRYPTION_KEY=replace-with-generated-value
